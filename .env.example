APP_NAME=Text To Doc Builder
APP_VERSION=0.1.0
APP_ENV=local
DEBUG=false
LOG_LEVEL=INFO

APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=sqlite:///./storage/app.db
ARTIFACT_STORAGE_PATH=./storage/artifacts

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=
OPENROUTER_CODEGEN_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_TIMEOUT_SECONDS=60

DEFAULT_OUTPUT_FORMAT=docx
DEFAULT_LANGUAGE=ru
DEFAULT_STYLE=business
DEFAULT_TONE=neutral
DEFAULT_FONT_FAMILY=Times New Roman
DEFAULT_FONT_SIZE=12

PUBLIC_BASE_URL=http://localhost:8000
API_INTERNAL_TOKEN=

WORKER_ENABLED=true
WORKER_CONCURRENCY=1
WORKER_POLL_INTERVAL_SECONDS=0.2

DOCX_CODEGEN_ENABLED=true
DOCX_CODEGEN_FALLBACK_ENABLED=true
DOCX_CODEGEN_IMAGE=text-to-doc-builder-docx-runtime:local
DOCX_CODEGEN_TIMEOUT_SECONDS=30
DOCX_CODEGEN_MEMORY_LIMIT=256m
DOCX_CODEGEN_CPU_LIMIT=1
DOCX_VALIDATION_ENABLED=true
DOCX_CODEGEN_REPAIR_ATTEMPTS=1
